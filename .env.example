# Host del servidor MySQL o MariaDB donde reside la base del CRM.
DB_HOST=localhost
# Usuario de conexion a la base de datos.
DB_USER=crm_db_user
# Contrasena del usuario de base de datos (sustituir por la de tu entorno).
DB_PASSWORD=your_database_password
# Nombre del esquema o base de datos del CRM.
DB_NAME=db_name
# Puerto TCP en el que escucha la API Express.
PORT=3000
# Hostname del servidor SMTP para el envio de correos (recuperacion de contrasena).
EMAIL_HOST=smtp.example.com
# Puerto del servicio SMTP (p. ej. 587 para STARTTLS o 465 para SSL).
EMAIL_PORT=587
# Direccion de correo autenticada en el servidor SMTP (remitente).
EMAIL_USER=noreply@example.com
# Contrasena o contrasena de aplicacion del buzon SMTP anterior.
EMAIL_PASS=your_smtp_password
# URL base de la API REST que consumira el frontend en tiempo de build (incluir sufijo /api si corresponde).
VITE_API_URL=http://localhost:3000/api

# Firebase (pendiente) — Hito 3: SDK web, firebase-admin y custom claims de rol.
# Clave API publica del proyecto Firebase para inicializar el cliente en el navegador.
# VITE_FIREBASE_API_KEY=your-firebase-web-api-key
# Dominio de autenticacion asociado al proyecto Firebase (Auth).
# VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# Identificador del proyecto en Firebase/Google Cloud.
# VITE_FIREBASE_PROJECT_ID=your-project-id
# Bucket de Cloud Storage configurado para el proyecto.
# VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# ID del remitente de Firebase Cloud Messaging (FCM) para notificaciones web.
# VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
# ID de la aplicacion web registrada en la consola de Firebase.
# VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
# Email de la cuenta de servicio de Firebase Admin SDK en el backend.
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fake@your-project-id.iam.gserviceaccount.com
# Clave privada PEM de la cuenta de servicio (sustituir saltos de linea por \n en .env real).
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nEXAMPLE_KEY_MATERIAL\n-----END PRIVATE KEY-----\n"
