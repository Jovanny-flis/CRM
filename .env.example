# Host del servidor MySQL o MariaDB donde reside la base del CRM.
DB_HOST=localhost
# Usuario de conexion a la base de datos.
DB_USER=crm_db_user
# Contrasena del usuario de base de datos (sustituir por la de tu entorno).
DB_PASSWORD=your_database_password
# Nombre del esquema o base de datos del CRM.
DB_NAME=db_name
# Puerto TCP en el que escucha la API Express.
PORT=3000
# Hostname del servidor SMTP para el envio de correos (recuperacion de contrasena).
EMAIL_HOST=smtp.example.com
# Puerto SMTP. Usar 465 para SSL (secure: true) o 587 para STARTTLS (secure: false). El transporter actual en index.js usa secure: true — se recomienda 465.
EMAIL_PORT=465
# Direccion de correo autenticada en el servidor SMTP (remitente).
EMAIL_USER=noreply@example.com
# Contrasena o contrasena de aplicacion del buzon SMTP anterior.
EMAIL_PASS=your_smtp_password
# NOTA: Esta variable debe configurarse en frontend/.env, no en este archivo. Vite solo lee variables desde el directorio del frontend.
FRONTEND_BASE_URL=http://localhost:5173
# Origenes permitidos para CORS.
CORS_ORIGINS=http://localhost:5173
