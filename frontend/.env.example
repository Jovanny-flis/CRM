# --- ViteAPI URL ---
VITE_API_URL=http://domain.com:PORT/api
# Clave API publica del proyecto Firebase para inicializar el cliente en el navegador.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
# Dominio de autenticacion asociado al proyecto Firebase (Auth).
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# Identificador del proyecto en Firebase/Google Cloud.
VITE_FIREBASE_PROJECT_ID=your-project-id
# Bucket de Cloud Storage configurado para el proyecto.
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# ID del remitente de Firebase Cloud Messaging (FCM) para notificaciones web.
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
# ID de la aplicacion web registrada en la consola de Firebase.
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
